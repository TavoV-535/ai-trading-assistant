# Copy to .env — never commit the real file.

# ---------- environment ----------
APP_ENV=development                # development | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ---------- database ----------
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_assistant

# ---------- discord ----------
# Created at https://discord.com/developers/applications
# Milestone 1 does not require this — filled in when Discord wiring lands.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ---------- reasoning engine (AI) ----------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
REASONING_MODEL=claude-opus-4-8

# ---------- market data (added in later milestones) ----------
POLYGON_API_KEY=
FINNHUB_API_KEY=
